<Window x:Class="MonitorColorControl.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Monitor Color Control" 
        Height="700" 
        Width="1200"
        Background="#1E1E1E"
        Foreground="#FFFFFF"
        WindowStartupLocation="CenterScreen"
        Icon="data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNk+M9QDwADhgGAWjR9awAAAABJRU5ErkJggg==">
    <Grid Background="#1E1E1E">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <!-- Left Panel: Profile Management -->
        <Border Grid.Column="0" Background="#2D2D2D" Padding="15">
            <StackPanel VerticalAlignment="Top">
                <TextBlock Text="PROFILES" FontSize="14" FontWeight="Bold" Margin="0,0,0,15" Foreground="#00A0F0" />

                <!-- Profile List -->
                <TextBlock Text="Saved Profiles:" FontSize="11" Margin="0,0,0,8" />
                <ListBox x:Name="ProfileListBox" 
                         Height="250" 
                         Background="#3F3F3F" 
                         Foreground="#FFFFFF"
                         BorderBrush="#555555"
                         SelectionChanged="ProfileListBox_SelectionChanged" />

                <!-- Profile Name Input -->
                <TextBlock Text="Profile Name:" FontSize="11" Margin="0,15,0,5" />
                <TextBox x:Name="ProfileNameTextBox" 
                         Background="#3F3F3F" 
                         Foreground="#FFFFFF"
                         BorderBrush="#555555"
                         Padding="8"
                         Height="32" />

                <!-- Profile Category -->
                <TextBlock Text="Category:" FontSize="11" Margin="0,10,0,5" />
                <ComboBox x:Name="CategoryComboBox" 
                          Background="#3F3F3F" 
                          Foreground="#FFFFFF"
                          BorderBrush="#555555"
                          Height="32" 
                          Padding="8">
                    <ComboBoxItem>Gaming</ComboBoxItem>
                    <ComboBoxItem>Movies</ComboBoxItem>
                    <ComboBoxItem>Work</ComboBoxItem>
                    <ComboBoxItem>Custom</ComboBoxItem>
                </ComboBox>

                <!-- Action Buttons -->
                <StackPanel Orientation="Vertical" Margin="0,15,0,0">
                    <Button Content="Save Profile" Click="SaveProfile_Click" Height="36" Margin="0,5" />
                    <Button Content="Load Profile" Click="LoadProfile_Click" Height="36" Margin="0,5" />
                    <Button Content="Delete Profile" Click="DeleteProfile_Click" Height="36" Margin="0,5" />
                </StackPanel>

                <!-- Import/Export -->
                <StackPanel Orientation="Vertical" Margin="0,15,0,0">
                    <Button Content="Import Profile" Click="ImportProfile_Click" Height="36" Margin="0,5" />
                    <Button Content="Export Profile" Click="ExportProfile_Click" Height="36" Margin="0,5" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Center Panel: Color Controls -->
        <Border Grid.Column="1" Background="#1E1E1E" Padding="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel VerticalAlignment="Top">
                    <TextBlock Text="COLOR CONTROLS" FontSize="16" FontWeight="Bold" Margin="0,0,0,20" Foreground="#00A0F0" />

                    <!-- Gamma -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Gamma" VerticalAlignment="Center" />
                        <Slider x:Name="GammaSlider" 
                                Grid.Column="1" 
                                Minimum="0.1" 
                                Maximum="5.0" 
                                Value="1.0" 
                                Margin="15,0"
                                ValueChanged="Slider_ValueChanged" />
                        <TextBlock x:Name="GammaValue" Grid.Column="2" Text="1.0" VerticalAlignment="Center" TextAlignment="Right" />
                    </Grid>

                    <!-- Brightness -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Brightness" VerticalAlignment="Center" />
                        <Slider x:Name="BrightnessSlider" 
                                Grid.Column="1" 
                                Minimum="-100" 
                                Maximum="300" 
                                Value="0" 
                                Margin="15,0"
                                ValueChanged="Slider_ValueChanged" />
                        <TextBlock x:Name="BrightnessValue" Grid.Column="2" Text="0" VerticalAlignment="Center" TextAlignment="Right" />
                    </Grid>

                    <!-- Contrast -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Contrast" VerticalAlignment="Center" />
                        <Slider x:Name="ContrastSlider" 
                                Grid.Column="1" 
                                Minimum="0" 
                                Maximum="300" 
                                Value="100" 
                                Margin="15,0"
                                ValueChanged="Slider_ValueChanged" />
                        <TextBlock x:Name="ContrastValue" Grid.Column="2" Text="100" VerticalAlignment="Center" TextAlignment="Right" />
                    </Grid>

                    <!-- Saturation -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Saturation" VerticalAlignment="Center" />
                        <Slider x:Name="SaturationSlider" 
                                Grid.Column="1" 
                                Minimum="0" 
                                Maximum="500" 
                                Value="100" 
                                Margin="15,0"
                                ValueChanged="Slider_ValueChanged" />
                        <TextBlock x:Name="SaturationValue" Grid.Column="2" Text="100%" VerticalAlignment="Center" TextAlignment="Right" />
                    </Grid>

                    <!-- Vibrance -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Vibrance" VerticalAlignment="Center" />
                        <Slider x:Name="VibranceSlider" 
                                Grid.Column="1" 
                                Minimum="0" 
                                Maximum="500" 
                                Value="0" 
                                Margin="15,0"
                                ValueChanged="Slider_ValueChanged" />
                        <TextBlock x:Name="VibranceValue" Grid.Column="2" Text="0%" VerticalAlignment="Center" TextAlignment="Right" />
                    </Grid>

                    <!-- Color Temperature -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Color Temp (K)" VerticalAlignment="Center" />
                        <Slider x:Name="ColorTempSlider" 
                                Grid.Column="1" 
                                Minimum="3000" 
                                Maximum="10000" 
                                Value="6500" 
                                Margin="15,0"
                                ValueChanged="Slider_ValueChanged" />
                        <TextBlock x:Name="ColorTempValue" Grid.Column="2" Text="6500" VerticalAlignment="Center" TextAlignment="Right" />
                    </Grid>

                    <!-- RGB Channels Section -->
                    <TextBlock Text="RGB CHANNELS" FontSize="13" FontWeight="Bold" Margin="0,20,0,15" Foreground="#00A0F0" />

                    <!-- Red Channel -->
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Red" VerticalAlignment="Center" Foreground="#FF6B6B" />
                        <Slider x:Name="RedSlider" 
                                Grid.Column="1" 
                                Minimum="-100" 
                                Maximum="100" 
                                Value="0" 
                                Margin="15,0"
                                ValueChanged="Slider_ValueChanged" />
                        <TextBlock x:Name="RedValue" Grid.Column="2" Text="0" VerticalAlignment="Center" TextAlignment="Right" />
                    </Grid>

                    <!-- Green Channel -->
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Green" VerticalAlignment="Center" Foreground="#51CF66" />
                        <Slider x:Name="GreenSlider" 
                                Grid.Column="1" 
                                Minimum="-100" 
                                Maximum="100" 
                                Value="0" 
                                Margin="15,0"
                                ValueChanged="Slider_ValueChanged" />
                        <TextBlock x:Name="GreenValue" Grid.Column="2" Text="0" VerticalAlignment="Center" TextAlignment="Right" />
                    </Grid>

                    <!-- Blue Channel -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Blue" VerticalAlignment="Center" Foreground="#4ECDC4" />
                        <Slider x:Name="BlueSlider" 
                                Grid.Column="1" 
                                Minimum="-100" 
                                Maximum="100" 
                                Value="0" 
                                Margin="15,0"
                                ValueChanged="Slider_ValueChanged" />
                        <TextBlock x:Name="BlueValue" Grid.Column="2" Text="0" VerticalAlignment="Center" TextAlignment="Right" />
                    </Grid>

                    <!-- Black and White Levels -->
                    <TextBlock Text="LEVELS" FontSize="13" FontWeight="Bold" Margin="0,20,0,15" Foreground="#00A0F0" />

                    <!-- Black Level -->
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Black Level" VerticalAlignment="Center" />
                        <Slider x:Name="BlackLevelSlider" 
                                Grid.Column="1" 
                                Minimum="0" 
                                Maximum="100" 
                                Value="0" 
                                Margin="15,0"
                                ValueChanged="Slider_ValueChanged" />
                        <TextBlock x:Name="BlackLevelValue" Grid.Column="2" Text="0" VerticalAlignment="Center" TextAlignment="Right" />
                    </Grid>

                    <!-- White Level -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="White Level" VerticalAlignment="Center" />
                        <Slider x:Name="WhiteLevelSlider" 
                                Grid.Column="1" 
                                Minimum="0" 
                                Maximum="100" 
                                Value="100" 
                                Margin="15,0"
                                ValueChanged="Slider_ValueChanged" />
                        <TextBlock x:Name="WhiteLevelValue" Grid.Column="2" Text="100" VerticalAlignment="Center" TextAlignment="Right" />
                    </Grid>

                    <!-- Extreme Mode Checkbox -->
                    <CheckBox x:Name="ExtremeModeCheckBox" 
                              Content="Enable Extreme Mode" 
                              Foreground="#FFD700"
                              Margin="0,20,0,20"
                              Checked="ExtremeMode_Checked"
                              Unchecked="ExtremeMode_Unchecked" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Right Panel: Preview and Actions -->
        <Border Grid.Column="2" Background="#2D2D2D" Padding="15">
            <StackPanel VerticalAlignment="Top">
                <TextBlock Text="PREVIEW" FontSize="14" FontWeight="Bold" Margin="0,0,0,15" Foreground="#00A0F0" />

                <!-- Color Preview -->
                <Border x:Name="PreviewBox" 
                        Height="150" 
                        Background="#777777" 
                        BorderBrush="#555555" 
                        BorderThickness="2"
                        CornerRadius="4"
                        Margin="0,0,0,20" />

                <!-- Monitor Selection -->
                <TextBlock Text="Monitor:" FontSize="11" Margin="0,0,0,5" />
                <ComboBox x:Name="MonitorComboBox" 
                          Background="#3F3F3F" 
                          Foreground="#FFFFFF"
                          BorderBrush="#555555"
                          Height="32"
                          Padding="8"
                          SelectionChanged="MonitorComboBox_SelectionChanged" />

                <!-- Apply to All Monitors -->
                <CheckBox x:Name="ApplyAllMonitorsCheckBox" 
                          Content="Apply to All Monitors" 
                          Foreground="#B0B0B0"
                          Margin="0,10,0,20" />

                <!-- Main Action Buttons -->
                <Button Content="Apply Settings" 
                        Click="ApplySettings_Click" 
                        Height="40" 
                        Margin="0,0,0,10"
                        FontSize="13"
                        FontWeight="Bold" />

                <Button Content="Reset" 
                        Click="Reset_Click" 
                        Height="40" 
                        Margin="0,0,0,10" />

                <Button Content="Undo" 
                        Click="Undo_Click" 
                        Height="40" 
                        Margin="0,0,0,20" />

                <!-- Settings -->
                <TextBlock Text="SETTINGS" FontSize="13" FontWeight="Bold" Margin="0,20,0,15" Foreground="#00A0F0" />

                <CheckBox x:Name="AutoStartCheckBox" 
                          Content="Auto-apply on startup" 
                          Foreground="#B0B0B0"
                          Margin="0,5,0,5" />

                <CheckBox x:Name="MinimizeToTrayCheckBox" 
                          Content="Minimize to tray" 
                          Foreground="#B0B0B0"
                          IsChecked="True"
                          Margin="0,5,0,5" />

                <CheckBox x:Name="StartMinimizedCheckBox" 
                          Content="Start minimized" 
                          Foreground="#B0B0B0"
                          Margin="0,5,0,20" />

                <!-- Status Message -->
                <TextBlock x:Name="StatusTextBlock" 
                           Text="Ready" 
                           Foreground="#28A745"
                           Margin="0,20,0,0"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</Window>